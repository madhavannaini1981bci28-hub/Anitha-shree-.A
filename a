# Enter your code here. Read input from STDIN. Print output to STDOUT
# Input format: N M (e.g., 7 21)
n, m = map(int, input().split())

# Top half of the mat
for i in range(1, n, 2):
    pattern = (i * ".|.").center(m, "-")
    print(pattern)

# Middle "WELCOME" line
print("WELCOME".center(m, "-"))

# Bottom half of the mat (reverse of top half)
for i in range(n-2, -1, -2):
    pattern = (i * ".|.").center(m, "-")
    print(pattern)
